<h1>New game</h1>

<p><%@result.each do |element|%>
  <%=element%>
<%end%></p>

<form action="/score" method="post">
  <input type="text" name="word">
  <label for="word"></label>
  
  <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
  <%= hidden_field_tag :result, @result %>
  <input type="submit">

</form>